{
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./buildcache",
    "target": "es2020",
    "module": "commonjs",
    "types": ["node"],
    "lib": ["es2020"],
    "pretty": true,
    "inlineSourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": false,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "declaration": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "test", "scripts"]
}
