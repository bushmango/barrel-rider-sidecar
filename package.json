{
  "name": "barrel-rider-sidecar2",
  "description": "create index sidecar files for typescript",
  "version": "2.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "bin": {
    "barrel-rider-sidecar2": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "dependencies": {
    "@parcel/watcher": "^2.5.1",
    "command-line-args": "^5.1.1",
    "command-line-usage": "6.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2"
  },
  "scripts": {
    "start": "ts-node --project tsconfig.json index.ts",
    "dev": "ts-node --project tsconfig.json index.ts",
    "test:verify": "ts-node --project tsconfig.json test_verify.ts after-test",
    "clean-test:verify": "ts-node --project tsconfig.json test_verify.ts after-clean-test",
    "test": "yarn start --src test --verbose --remove && yarn test:verify",
    "clean-test": "yarn start --src test --verbose --removeOnly && yarn clean-test:verify",
    "build": "tsc -p tsconfig.json",
    "self-barrel": "ts-node --project tsconfig.json index.ts --src ./ --remove"
  },
  "devDependencies": {
    "@types/command-line-args": "^5.2.3",
    "@types/command-line-usage": "^5.0.4",
    "@types/node": "^22.19.17"
  }
}
